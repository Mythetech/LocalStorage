<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>

    <Authors>Mythetech</Authors>
    <Company>Mythetech</Company>
    <Copyright>Copyright 2019 Chris Sainty. Copyright 2026 Mythetech. All rights reserved.</Copyright>
    <Description>A testing library to provide helper extensions for Mythetech.LocalStorage. Fork of Blazored.LocalStorage.TestExtensions.</Description>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>

    <!-- NuGet settings -->
    <PackageId>Mythetech.LocalStorage.TestExtensions</PackageId>
    <PackageTags>Mythetech;Blazor;Razor;Components;LocalStorage;Local Storage;ASP.NET Core;CSharp;Web;Testing</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/Mythetech/LocalStorage</PackageProjectUrl>
    <PackageIcon>icon.png</PackageIcon>
    <RepositoryType>git</RepositoryType>
    <RepositoryUrl>https://github.com/Mythetech/LocalStorage</RepositoryUrl>

    <!-- SourceLink settings -->
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>..\Mythetech.LocalStorage\Mythetech.LocalStorage.snk</AssemblyOriginatorKeyFile>
  </PropertyGroup>

  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\Mythetech.LocalStorage\icon.png" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="bunit.core" Version="1.31.3" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Mythetech.LocalStorage\Mythetech.LocalStorage.csproj" />
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
      <_Parameter1>
        Mythetech.LocalStorage.Tests, 
      </_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

  <ItemGroup>
    <None Include="..\Mythetech.LocalStorage\Mythetech.LocalStorage.snk" Link="Mythetech.LocalStorage.snk" />
  </ItemGroup>

</Project>
